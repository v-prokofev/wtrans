#!/bin/sh
# =============================================================================
# pre-commit hook — WindTrans firmware auto-versioning
#
# Increments FW_VERSION_BUILD in fw/Core/Inc/version.h on every commit.
# The build number equals the total number of commits on the current branch
# (git rev-list --count HEAD + 1 for the upcoming commit).
#
# MAJOR and MINOR are defined here; change them manually when needed.
# =============================================================================

set -e

MAJOR=1
MINOR=1

VERSION_H="fw/Core/Inc/version.h"

# Repo root (hook runs from repo root when invoked by git)
if [ ! -f "$VERSION_H" ]; then
    echo "[pre-commit] ERROR: $VERSION_H not found. Run scripts/install_hooks.ps1 first."
    exit 1
fi

# Build number = current commit count + 1 (for the commit being created)
# On an empty repo HEAD doesn't exist yet, so guard against that.
if git rev-parse --verify HEAD >/dev/null 2>&1; then
    BUILD=$(git rev-list --count HEAD)
    BUILD=$((BUILD + 1))
else
    BUILD=1
fi

VERSION_STR=$(printf "%d.%d.%03d" $MAJOR $MINOR $BUILD)

# Write new version.h
cat > "$VERSION_H" << HEADER_EOF
/* ============================================================
 * version.h  —  WindTrans firmware version
 *
 * AUTO-GENERATED by scripts/hooks/pre-commit.
 * Do NOT edit manually — changes will be overwritten on next commit.
 * To bump MAJOR or MINOR, edit FW_VERSION_MAJOR / FW_VERSION_MINOR
 * in scripts/hooks/pre-commit and commit once to take effect.
 * ============================================================ */
#ifndef VERSION_H
#define VERSION_H

#define FW_VERSION_MAJOR  ${MAJOR}
#define FW_VERSION_MINOR  ${MINOR}
#define FW_VERSION_BUILD  ${BUILD}

#define FW_VERSION        "${VERSION_STR}"

#endif /* VERSION_H */
HEADER_EOF

git add "$VERSION_H"

echo "[pre-commit] Version bumped -> ${VERSION_STR}"
